# fi-code E2E 测试配置示例
# 复制这个文件为 .env 并根据需要修改

# ============================================
# Mock AI 开关
# ============================================
# true  = 使用 Mock AI（默认，快速，无需 API）
# false = 连接真实 AI  API
USE_MOCK_AI=true

# ============================================
# 服务器配置
# ============================================
# fi-code 服务器端口
SERVER_PORT=4041

# Vite 前端服务器端口
FRONTEND_PORT=3001

# Mock AI 服务器端口
MOCK_SERVER_PORT=8888

# ============================================
# 测试项目配置
# ============================================
# 测试项目目录
TEST_PROJECT_DIR=/tmp/fi_code_test/test_project

# ============================================
# 浏览器配置
# ============================================
# true  = 无头模式（不显示浏览器）
# false = 有头模式（显示浏览器窗口）
HEADLESS=false

# 浏览器类型：chromium, firefox, webkit
BROWSER_TYPE=chromium

# ============================================
# 超时配置
# ============================================
# 页面加载超时（毫秒）
PAGE_LOAD_TIMEOUT=30000

# 浏览器操作超时（毫秒）
BROWSER_TIMEOUT=30000

# SSE 等待超时（毫秒）
SSE_WAIT_TIMEOUT=60000

# 测试用例超时（秒）
TEST_TIMEOUT=300
